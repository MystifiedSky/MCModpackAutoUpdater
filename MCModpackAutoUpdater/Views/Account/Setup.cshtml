@model SetupViewModel
@{
    ViewData["Title"] = "Setup";
}

<section class="panel narrow">
    <h1>First Admin Setup</h1>
    <p class="muted">Enter the setup token from the AMP console log, then create the first administrator account. The current token is logged each time this page is opened while no users exist.</p>
    <form method="post">
        <div asp-validation-summary="All" class="validation"></div>
        <label asp-for="SetupToken"></label>
        <input asp-for="SetupToken" autocomplete="one-time-code" />
        <label asp-for="UserName"></label>
        <input asp-for="UserName" autocomplete="username" />
        <label asp-for="Email"></label>
        <input asp-for="Email" autocomplete="email" />
        <label asp-for="Password"></label>
        <input asp-for="Password" autocomplete="new-password" />
        <label asp-for="ConfirmPassword"></label>
        <input asp-for="ConfirmPassword" autocomplete="new-password" />
        <button type="submit" class="primary">Create Admin</button>
    </form>
</section>
