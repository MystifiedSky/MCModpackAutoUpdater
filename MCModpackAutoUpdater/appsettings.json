{
  "WebUi": {
    "Enabled": true,
    "BindUrl": "http://0.0.0.0:9090",
    "DatabasePath": "mc-modpack-auto-updater.db",
    "SessionMinutes": 480
  },
  "Agent": {
    "ModpackSync": {
      "MaxWarningMinutes": 240,
      "FailIfRestartModeUnconfigured": false,
