{
  "Agent": {
    "ApiBaseUrl": "http://localhost:9090",
    "AuthToken": "replace-with-agent-token",
    "AgentVersion": "",
    "PollIntervalSeconds": 30,
    "ErrorBackoffSeconds": 15,
    "CommandBatchSize": 20,
    "HttpTimeoutSeconds": 30,
    "ModpackSync": {
      "MaxWarningMinutes": 240,
      "FailIfRestartModeUnconfigured": false,
      "AmpApi": {
        "Enabled": false,
        "Username": "",
        "Password": "",
        "Token": "",
        "RememberMe": true,
        "WarningMessageTemplate": "say Server will restart in {warningMinutes} minute(s) for an automatic modpack update to {targetVersionDisplay}. Please update your clients."
      },
      "RestartModes": {
        "amp": {
          "WarningCommandTemplate": "",
          "StopCommandTemplate": "",
          "StartCommandTemplate": ""
        }
      }
    },
    "SelfUpdate": {
      "Enabled": true,
      "WorkDirectory": "updates",
      "ApplyCommandTemplate": "",
      "AllowApplyCommandFromPayload": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
